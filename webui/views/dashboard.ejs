<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>VPN Dashboard</title>
    <%- include('partials/icons') %>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/dashboard.css" />
  </head>

  <body class="d-flex justify-content-center align-items-center vh-100">

    <div class="bg-glow"></div>

    <div class="dashboard text-center">
      <h3 class="mb-3">VPN Dashboard</h3>

      <div class="status-box">
        <div class="status-dot"></div>
        <span>Connection active and secure</span>
      </div>

      <div class="connection">
        Server: <span class="server" id="serverLocation">Loading...</span><br />
        IP: <span id="serverIp">Loading...</span><br />
        Provider: <span id="serverIsp">Loading...</span>
      </div>

      <button
        id="connectBtn"
        class="btn btn-success w-100 btn-glow mb-2"
        type="button"
        disabled
        data-status="probing"
        title="Looking for the browser extension..."
      >
        Looking for extension...
      </button>

      <div id="connectMessage" class="small text-muted mb-2" role="status" aria-live="polite"></div>

      <a href="/user/profile" class="btn btn-info w-100 btn-glow mb-2">
        User Panel
      </a>

      <a href="/auth/desktop-pairing" class="btn btn-secondary w-100 btn-glow mb-2">
        Pair Desktop Client
      </a>

      <form method="POST" action="/api/auth/logout">
        <button class="btn btn-danger w-100 btn-glow">Sign Out</button>
      </form>
    </div>
    <% if (typeof newRegistration !== 'undefined' && newRegistration) { %>
      <div id="welcomePopup" class="popup-overlay">
        <div class="popup-card">
          <button class="close-btn" onclick="closePopup()">&times;</button>
          <h3 class="text-success mb-3" style="font-weight: 700;">Your account is ready! 🎉</h3>
          <p class="mb-4" style="color: #9ca3af; font-size: 14px;">
            Your wallet is now linked. You can view your identity details on the User Panel.
          </p>
        </div>
      </div>
      <script src="/js/dashboard/popup.js"></script>
    <% } %>

    <script src="/js/dashboard/dashboard-api.js">

    </script>

  </body>
</html>
