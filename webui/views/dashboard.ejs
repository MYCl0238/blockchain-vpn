<!DOCTYPE html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <title>VPN Dashboard</title>
    <%- include('partials/icons') %>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/dashboard.css" />
  </head>

  <body class="d-flex justify-content-center align-items-center vh-100">
    
    <div class="bg-glow"></div>

    <div class="dashboard text-center">
      <h3 class="mb-3">VPN Dashboard</h3>

      <div class="status-box">
        <div class="status-dot"></div>
        <span>Bağlantı aktif ve güvenli</span>
      </div>

      <div class="connection">
        Sunucu: <span class="server" id="serverLocation">Yükleniyor...</span><br />
        IP: <span id="serverIp">Yükleniyor...</span><br />
        Sağlayıcı: <span id="serverIsp">Yükleniyor...</span>
      </div>

      <button
        id="connectBtn"
        class="btn btn-success w-100 btn-glow mb-2"
        type="button"
        disabled
        data-status="probing"
        title="Tarayıcı eklentisi aranıyor..."
      >
        Eklenti aranıyor...
      </button>

      <div id="connectMessage" class="small text-muted mb-2" role="status" aria-live="polite"></div>

      <a href="/user/profile" class="btn btn-info w-100 btn-glow mb-2">
        Kullanıcı Paneli
      </a>

      <form method="POST" action="/api/auth/logout">
        <button class="btn btn-danger w-100 btn-glow">Bağlantıyı Kes</button>
      </form>
    </div>
    <% if (typeof yeniKayıt !== 'undefined' && yeniKayıt) { %>
        <div id="welcomePopup" class="popup-overlay">
          <div class="popup-card">
          <button class="close-btn" onclick="closePopup()">&times;</button> 
          <h3 class="text-success mb-3" style="font-weight: 700;">Kayıt Başarılı! 🎉</h3>
          <p class="mb-4" style="color: #9ca3af; font-size: 14px;">
            Bu sizin anahtarınızdır. Lütfen giriş yapabilmek için kopyalayıp güvenli bir yere kaydedin.
          </p>
        <div class="info-box d-flex justify-content-between align-items-center mb-3">
          <div class="text-start">
            <div class="info-label">Kullanıcı ID</div>
            <div class="info-value" id="newUserId"><%= yeniKayıt.id %></div>
          </div>
          <button class="btn btn-sm btn-outline-light copy-btn" onclick="copyId()">Kopyala</button>
        </div>
      <div class="info-box text-start">
        <div class="info-label">Kayıtlı E-Posta</div>
        <div class="info-value" style="letter-spacing: normal;">
          <%= yeniKayıt.mail ? yeniKayıt.mail : "Belirtilmedi" %>
        </div>
      </div>
    </div>
    
  </div>
  
  <script src="/js/dashboard/popup.js"></script>  
<% } %>

    <script src="/js/dashboard/dashboard-api.js">
      
    </script>

  </body>
</html>
