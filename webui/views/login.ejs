<!DOCTYPE html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login</title>
    <%- include('partials/icons') %>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/login.css" />

    <style></style>
  </head>

  <body>
    <div class="bg"></div>
    <div class="bg"></div>

    <div class="card-modern">
      <h2>Güvenli Giriş 🔒</h2>

      <form action="/api/auth/login" method="POST" id="loginForm">
        <div
          class="mb-5 d-flex justify-content-center align-items-center gap-2"
        >
          <input
            type="text"
            class="form-control key-input"
            maxlength="4"
            required
          />
          <span class="dash">-</span>
          <input
            type="text"
            class="form-control key-input"
            maxlength="4"
            required
          />
          <span class="dash">-</span>
          <input
            type="text"
            class="form-control key-input"
            maxlength="4"
            required
          />
          <span class="dash">-</span>
          <input
            type="text"
            class="form-control key-input"
            maxlength="4"
            required
          />
        </div>

        <input type="hidden" name="id" id="realLoginKey" />

        <button type="submit" class="btn btn-modern w-100">Bağlan</button>
        <button
          class="btn btn-modern w-50 btn-back"
          onclick="window.history.back()"
        >
          Geri Dön
        </button>
      </form>
    </div>

    <%- include('partials/pop-up') %>
    <script src="/js/login.js"></script>
  </body>
</html>
