<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login</title>
    <%- include('partials/icons') %>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/login.css" />
  </head>

  <body>
    <div class="bg"></div>
    <div class="bg"></div>

    <div class="card-modern">
      <h2>Secure Sign In 🔒</h2>

      <p class="lead-text">
        Sign a message with your wallet to log in.
      </p>

      <button
        type="button"
        class="btn btn-modern btn-metamask w-100"
        data-wallet-purpose="login"
      >
        Sign in with MetaMask
      </button>
      <div id="walletError" class="wallet-error"></div>

      <a href="/auth/register" class="btn btn-modern btn-outline w-100 mt-2">
        No account yet? Sign up
      </a>
      <button
        class="btn btn-modern w-50 btn-back"
        onclick="window.history.back()"
      >
        Back
      </button>
    </div>

    <%- include('partials/pop-up') %>
    <script src="/js/wallet-auth.js"></script>
  </body>
</html>
