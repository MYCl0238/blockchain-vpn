<!DOCTYPE html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Kullanici Profili</title>
    <%- include('partials/icons') %>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/profile.css" />
    <style></style>
  </head>
  <body>
    <div class="bg-orb"></div>
    <div class="bg-orb"></div>

    <div class="profile-card">
      <h2>Kullanıcı Paneli</h2>

      <div class="info-box">
        <div class="info-label">Cüzdan Adresi</div>
        <div class="info-value mono"><%= user.wallet_address || "—" %></div>
      </div>

      <% if (typeof blockchainIdentity !== 'undefined' && blockchainIdentity) { %>
        <div class="info-box">
          <div class="info-label">Blockchain Kimlik</div>
          <div class="info-value mono"><%= blockchainIdentity.privateMemberId %></div>
          <div class="info-sub">
            <%= blockchainIdentity.blockCount %> blok ·
            <%= blockchainIdentity.chainValid ? "zincir geçerli" : "zincir hatalı" %>
            (<%= blockchainIdentity.chainBlockCount %> toplam)
          </div>
        </div>

        <% if (blockchainIdentity.latestBlock) { %>
          <div class="info-box">
            <div class="info-label">Son Blok</div>
            <div class="info-value mono">
              #<%= blockchainIdentity.latestBlock.block_index %> · <%= blockchainIdentity.latestBlock.event_type %>
            </div>
            <div class="info-sub mono"><%= blockchainIdentity.latestBlock.block_hash %></div>
          </div>
        <% } %>
      <% } %>

      <div class="info-box">
        <div class="info-label" style="text-align: center">Cihazlar</div>
        <!-- Onceki degisiklik: Cihazlar tablo olarak listelenir ve silme islemi form ile backend'e gider. -->
        <div class="devices-table-wrap">
          <table class="devices-table">
            <thead>
              <tr>
                <th>#</th>
                <th>Cihaz</th>
                <th>Token</th>
                <th>Durum</th>
                <th>Son Gorulme</th>
                <th>Islem</th>
              </tr>
            </thead>
            <tbody>
              <% if (!devices || devices.length === 0) { %>
                <tr>
                  <td colspan="6" class="empty-devices">Kayitli cihaz yok</td>
                </tr>
              <% } %>

              <% for( let index = 0; index < devices.length; index++ ) { %>
                <% const isCurrentDevice = devices[index].device_token === currentDeviceToken; %>
                <% const isNoiseDevice = noisePublicKey && devices[index].device_token === noisePublicKey; %>
                <% const isActive = isCurrentDevice || isNoiseDevice || devices[index].last_active === null; %>
                <tr>
                  <td><%= devices[index].id %></td>
                  <td>
                    <%= devices[index].device_type %><% if (isNoiseDevice) { %> <span class="status-badge status-active" style="margin-left:6px">Eslestirildi</span><% } %>
                  </td>
                  <td class="device-token"><%= devices[index].device_token %></td>
                  <td>
                    <span class="status-badge <%= isActive ? 'status-active' : 'status-passive' %>">
                      <%= isActive ? "Aktif" : "Pasif" %>
                    </span>
                  </td>
                  <td>
                    <%= isActive ? "-" : new Date(devices[index].last_active).toLocaleString("tr-TR") %>
                  </td>
                  <td>
                    <% if (isNoiseDevice) { %>
                      <button type="button" class="delete-device-btn unpair-noise-btn">Eslestirmeyi Cikar</button>
                    <% } else { %>
                      <form method="POST" action="/api/auth/devices/delete" class="delete-device-form">
                        <input type="hidden" name="deviceToken" value="<%= devices[index].device_token %>" />
                        <button type="submit" class="delete-device-btn">Sil</button>
                      </form>
                    <% } %>
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

      <a href="/dashboard" class="btn btn-modern">Dashboard'a Don</a>
    </div>

    <script>
      // Noise-paired client row: webui DELETE clears noise_public_key + the
      // devices row in one shot. The desktop/mobile client's local copy of
      // the key will be invalid on next handshake (server allowlist no
      // longer has it), so the user can re-pair from there.
      document.querySelectorAll(".unpair-noise-btn").forEach((btn) => {
        btn.addEventListener("click", async () => {
          if (!confirm("Bu cihazin eslestirmesini cikarmak istediginizden emin misiniz?")) return;
          btn.disabled = true;
          try {
            const res = await fetch("/api/wallet/noise-identity", {
              method: "DELETE",
              credentials: "include",
            });
            if (!res.ok) {
              const j = await res.json().catch(() => ({}));
              throw new Error(j.error || ("HTTP " + res.status));
            }
            window.location.reload();
          } catch (e) {
            alert("Eslestirme cikarilamadi: " + e.message);
            btn.disabled = false;
          }
        });
      });
    </script>
  </body>
</html>
