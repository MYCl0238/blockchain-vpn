<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign Up</title>
    <%- include('partials/icons') %>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/register.css" />
  </head>

  <body>
    <div class="bg"></div>
    <div class="bg"></div>

    <div class="card-modern">
      <h2>Create Account</h2>

      <p class="lead-text">
        Sign a message with your wallet to create a new Blockchain VPN account.
        You can add a recovery email later from the profile page.
      </p>

      <button
        type="button"
        class="btn btn-modern btn-metamask w-100"
        data-wallet-purpose="register"
      >
        Sign up with MetaMask
      </button>
      <div id="walletError" class="wallet-error"></div>

      <a href="/auth/login" class="btn btn-modern btn-outline w-100 mt-2">
        Already have an account? Sign in
      </a>
      <button class="btn btn-modern w-50" onclick="window.history.back()">
        Back
      </button>
    </div>
    <%- include('partials/pop-up') %>
    <script src="/js/wallet-auth.js"></script>
  </body>
</html>
