PORT=3000
SESSION_SECRET=change-me
SESSION_COOKIE_NAME=vpn_project.sid
SESSION_TABLE=user_sessions
SESSION_MAX_AGE_MS=604800000
SESSION_SECURE_COOKIE=false
TRUST_PROXY=false

DB_USER=postgres
DB_HOST=127.0.0.1
DB_NAME=vpn_project
DB_PASSWORD=change-me
DB_PORT=5432

# Linux bridge integration
# Set to false if you want to run the app without local VPN controls.
BVPN_UI_MODE=local-bridge
BVPN_APP_BRIDGE_ENABLED=true

# Absolute path recommended on Linux target device.
BVPN_APP_BRIDGE_BIN=/usr/local/bin/blockchain-vpn-app-bridge

# VPS monitoring mode
BVPN_CONTROL_BASE_URL=http://127.0.0.1:8787
BVPN_CONTROL_TOKEN=

BVPN_PUBLIC_CONTROL_LABEL=https://84.21.171.106
BVPN_PROXY_HOST=84.21.171.106
BVPN_PROXY_PORT=3128
BVPN_PROXY_SCHEME=http
BVPN_PROXY_USERNAME=
BVPN_PROXY_PASSWORD=
BVPN_PROXY_BYPASS_LIST=localhost,127.0.0.1,[::1]
