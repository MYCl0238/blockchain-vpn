{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Blockchain VPN",
  "version": "0.1.0",
  "identifier": "com.blockchainvpn.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:8081",
    "beforeDevCommand": "npx expo start --web --port 8081",
    "beforeBuildCommand": "npx expo export --platform web"
  },
  "app": {
    "windows": [
      {
        "title": "Blockchain VPN",
        "width": 520,
        "height": 920,
        "minWidth": 520,
        "minHeight": 920,
        "maxWidth": 520,
        "maxHeight": 920,
        "resizable": false,
        "maximizable": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
