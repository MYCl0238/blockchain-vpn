$env:BVPN_TUN_SERVER_HOST = "84.21.171.106"
$env:BVPN_TUN_SERVER_PORT = "443"
# BVPN_TUN_CIDR is overridden by the AUTO_LEASE response; keep .3/24 as a
# fallback only for offline/single-device testing.
$env:BVPN_TUN_CIDR = "10.99.0.3/24"
$env:BVPN_TUN_GATEWAY = "10.99.0.1"
$env:BVPN_TUN_BIND = ":0"
$env:BVPN_TUN_NAME = "bvpntun1"
$env:BVPN_TUN_ROUTE_DEFAULT = "true"
$env:BVPN_TUN_MTU = "1380"

# AUTO_LEASE pulls a per-device tunnel IP from the control plane on every
# start. Required when more than one client connects to the same server.
$env:BVPN_TUN_AUTO_LEASE = "true"
$env:BVPN_TUN_API_URL = "https://84.21.171.106/vpn-api"
# $env:BVPN_TUN_API_TOKEN = ""

# Set BVPN_TUN_CLIENT_ID to the device_token shown in the web UI
# (e.g. DEV-1234) to pin this machine to that account/slot. Otherwise the
# control plane will mint a c_<ts>_<rand> id on first connect.
# $env:BVPN_TUN_CLIENT_ID = "DEV-XXXX"

# Path to the Windows tunnel binary
# $env:BVPN_TUN_BIN = "C:\ProgramData\BlockchainVpn\bin\blockchain-vpn-tun-client.exe"

# Path to the Windows service supervisor binary
# $env:BVPN_TUN_SERVICE_BIN = "C:\ProgramData\BlockchainVpn\bin\blockchain-vpn-tun-service.exe"

# Optional Windows service name/display name
# $env:BVPN_TUN_SERVICE_NAME = "BlockchainVpnTunnel"
# $env:BVPN_TUN_SERVICE_DISPLAY_NAME = "Blockchain VPN Tunnel"

# Optional state root
# $env:BVPN_WINDOWS_HOME = "C:\ProgramData\BlockchainVpn"
# $env:BVPN_TUN_CLIENT_ID_FILE = "C:\ProgramData\BlockchainVpn\state\client-id.txt"
