# Root-level custom tunnel client
BVPN_TUN_BACKEND=custom
BVPN_TUN_SERVER=84.21.171.106:443
BVPN_TUN_NAME=bvpntun1
# BVPN_TUN_CIDR is overridden by the AUTO_LEASE response; keep .2/24 as a
# fallback only for offline/single-device testing.
BVPN_TUN_CIDR=10.99.0.2/24
BVPN_TUN_GATEWAY=10.99.0.1
BVPN_TUN_BIND=:0
BVPN_TUN_ROUTE_DEFAULT=true
BVPN_TUN_MTU=1380

# AUTO_LEASE pulls a per-device tunnel IP from the control plane on every
# start. Required when more than one client connects to the same server,
# otherwise both clients source-IP-collide and only one gets return traffic.
BVPN_TUN_AUTO_LEASE=true
BVPN_TUN_API_URL=https://84.21.171.106/vpn-api
# BVPN_TUN_API_TOKEN=

# BVPN_TUN_CLIENT_ID is the stable identifier the control plane uses to
# allocate a tunnel IP. Set this to the device_token shown in the web UI
# (e.g. DEV-1234) to pin this machine to that account/slot. If left empty,
# the control plane will mint a c_<ts>_<rand> id on first connect and the
# script will cache it under BVPN_TUN_CLIENT_ID_FILE.
# BVPN_TUN_CLIENT_ID=DEV-XXXX

# Optional overrides
# BVPN_TUN_CUSTOM_BIN=/usr/local/bin/blockchain-vpn-tun-client
# BVPN_TUN_PID_FILE=/run/blockchain-vpn-tun-client.pid
# BVPN_TUN_LOG_FILE=/var/log/blockchain-vpn-tun-client.log
# BVPN_TUN_CLIENT_ID_FILE=/var/lib/blockchain-vpn/tunnel-client-id
