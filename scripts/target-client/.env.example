# API control-plane (optional, only for connect.sh)
VPND_URL=http://SERVER_IP:8787
VPND_TOKEN=PUT_ONE_OF_YOUR_TOKENS_HERE
VPND_PROFILE_ID=demo

# Target worker (mobile + PC)
PROTO_SERVER_HOST=SERVER_IP
PROTO_SERVER_PORT=7000
PROTO_PSK=CHANGE_ME
PROTO_CLIENT_ID=device-01
PROTO_BIND=:0
PROTO_KEEPALIVE_MS=10000
PROTO_RECONNECT_MS=3000

# Optional override for binary path
# BVPN_WORKER_BIN=/absolute/path/to/blockchain-vpn-target-worker

# Linux custom full tunnel
# BVPN_TUN_BACKEND=custom
# BVPN_TUN_SERVER=SERVER_IP:7001
# BVPN_TUN_NAME=bvpntun1
# BVPN_TUN_CIDR=10.99.0.2/24
# BVPN_TUN_BIND=:0
# BVPN_TUN_ROUTE_DEFAULT=true
# BVPN_TUN_MTU=1380
# BVPN_TUN_CUSTOM_BIN=/absolute/path/to/blockchain-vpn-tun-client
