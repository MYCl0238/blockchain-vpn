# App-facing Linux bridge service
BVPN_APP_BRIDGE_DIR=/var/lib/blockchain-vpn/bridge
BVPN_APP_BRIDGE_RUNNER=/usr/local/bin/blockchain-vpn-app-bridge-runner
BVPN_APP_BRIDGE_SERVICE_POLL_SECS=0.5
BVPN_APP_BRIDGE_STATUS_INTERVAL_SECS=5

# Demo-friendly permissions for local single-user devices.
# Tighten these later with a dedicated group or ACL if needed.
BVPN_APP_BRIDGE_DIR_MODE=0o1777
BVPN_APP_BRIDGE_FILE_MODE=0o666
