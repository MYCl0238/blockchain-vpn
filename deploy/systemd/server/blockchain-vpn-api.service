[Unit]
Description=Blockchain VPN Control-Plane API
After=network.target

[Service]
Type=simple
EnvironmentFile=%h/.config/blockchain-vpn/api.env
WorkingDirectory=%h/blockchain-vpn
ExecStart=/usr/bin/node %h/blockchain-vpn/backend/control-plane/daemon.js
Restart=always
RestartSec=2

[Install]
WantedBy=default.target
