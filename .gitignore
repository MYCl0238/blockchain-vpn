# Secrets / runtime config
.env
.env.*
*.env

# Local daemon runtime data (may contain sensitive metadata)
data/*.json
data/*.ndjson
!data/.gitkeep

# OS/editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Logs
*.log
logs/

# allow examples
!*.env.example
!scripts/target-client/.env.example

# Go build output
bin/

# Stray Go build outputs (debug binaries dropped in cmd dirs)
protocol/udp/tun-client
protocol/udp/tun-client.exe
protocol/udp/tun-server

# gomobile bind output (regenerate with `gomobile bind -target=android ./protocol/udp/noisemobile`)
mobile/android/libs/*.aar

# Release staging dir — artifacts uploaded via `gh release` instead
releases/

# Vendored app build artifacts
apps/cross-platform-app/node_modules/
apps/cross-platform-app/dist/
apps/cross-platform-app/.expo/
apps/cross-platform-app/src-tauri/target/
apps/cross-platform-app/android/build/
apps/cross-platform-app/android/.gradle/
apps/cross-platform-app/android/.cxx/
apps/cross-platform-app/android/app/build/
apps/cross-platform-app/android/app/.cxx/
apps/cross-platform-app/android/local.properties

# Vendored webui build artifacts
webui/node_modules/
